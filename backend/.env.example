# Django Configuration
SECRET_KEY=django-insecure-change-me-run-bootstrap-to-generate
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.trycloudflare.com

# Database Configuration (PostgreSQL/pgvector)
# These defaults match the pgvector Docker container that bootstrap.ps1 launches.
# Host port 5544 is used to avoid clashing with any native PostgreSQL on 5432/5433.
DB_NAME=customer_ops
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5544

# Ollama Local Service Configuration
# Use 127.0.0.1 (not localhost) so the async client resolves to IPv4 and does not
# fall back to ::1, which Ollama may not be listening on.
# NOTE: You must pull these models yourself:  ollama pull llama3.2 nomic-embed-text
# The embedding model must be 768-dim (nomic-embed-text) to match embed_dim in the code.
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_LLM_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# Slack Configuration (consumed by the n8n orchestrator, not by Django)
SLACK_BOT_TOKEN=<YOUR_SLACK_BOT_TOKEN>
SLACK_APP_ID=<YOUR_SLACK_APP_ID>
SLACK_CLIENT_ID=<YOUR_SLACK_CLIENT_ID>
SLACK_CLIENT_SECRET=<YOUR_SLACK_CLIENT_SECRET>
SLACK_SIGNING_SECRET=<YOUR_SLACK_SIGNING_SECRET>
SLACK_VERIFICATION_TOKEN=<YOUR_SLACK_VERIFICATION_TOKEN>

# Jira Configuration (consumed by the n8n orchestrator, not by Django)
JIRA_API_TOKEN=<YOUR_JIRA_API_TOKEN>
JIRA_EMAIL=<YOUR_JIRA_EMAIL>
JIRA_SITE_URL=<YOUR_JIRA_SITE_URL>
